# PhotoEditor auth (CRM-style invite + session)
AUTH_ENABLED=true
FRONTEND_URL=http://127.0.0.1:8000

# Optional SMTP for invite emails (without SMTP, links go to data/invite_links.log)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=photoeditor@example.com
# SMTP_TLS=true
