# PhotoEditor — local development
APP_ENV=development
AUTH_ENABLED=true
APP_NAME=PhotoEditor
FRONTEND_URL=http://127.0.0.1:8000
COOKIE_SECURE=false
SESSION_DAYS=90

# --- Email (optional locally; required in production) ---
# Without SMTP/Cloudflare, invites are logged to data/invite_links.log

# Resend SMTP example:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASSWORD=re_xxxxxxxx
# SMTP_FROM=noreply@herooflegend.com
# SMTP_TLS=true

# Cloudflare Email Sending (optional alternative):
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# EMAIL_FROM=noreply@herooflegend.com
# EMAIL_FROM_NAME=PhotoEditor

# Durable auth (production). Prefer KV API credentials:
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# AUTH_KV_NAMESPACE_ID=589022e1c1d445f8a2ecc1826318f862
# Or Worker internal sync:
# AUTH_KV_URL=https://editor.herooflegend.com
# AUTH_SYNC_SECRET=
