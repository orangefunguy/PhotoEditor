# Production template for editor.herooflegend.com
# Copy to .env.production (never commit real secrets)

APP_ENV=production
AUTH_ENABLED=true
APP_NAME=PhotoEditor
FRONTEND_URL=https://editor.herooflegend.com
CORS_ORIGINS=https://editor.herooflegend.com
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
SESSION_DAYS=90
UVICORN_WORKERS=1
DISABLE_DOCS=false

# Durable auth — Cloudflare KV (accounts survive Render free restarts)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
AUTH_KV_NAMESPACE_ID=589022e1c1d445f8a2ecc1826318f862
# Fallback if not using the KV API directly:
# AUTH_KV_URL=https://editor.herooflegend.com
# AUTH_SYNC_SECRET=

# --- Email (pick ONE transport) ---

# Option A — Resend SMTP (recommended)
# 1. Create account at https://resend.com
# 2. Verify domain herooflegend.com
# 3. Create API key → use as SMTP password
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_xxxxxxxx
SMTP_FROM=noreply@herooflegend.com
SMTP_TLS=true
EMAIL_FROM=noreply@herooflegend.com
EMAIL_FROM_NAME=PhotoEditor

# Option B — Cloudflare Email Sending
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# EMAIL_FROM=noreply@herooflegend.com
